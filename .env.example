# ── Environment isolation (required) ─────────────────────────────────────────
# Local development MUST use LOCAL_DATABASE_URL — never production Neon.
# Production VPS uses PRODUCTION_DATABASE_URL or DATABASE_URL with NODE_ENV=production.

NODE_ENV=development

# REQUIRED for local development — DATABASE_URL fallback is disabled
LOCAL_DATABASE_URL=postgresql://user:pass@ep-dev-branch-pooler.region.aws.neon.tech/neondb?sslmode=require

# Production VPS only (NODE_ENV=production) — required on server
# DATABASE_URL=postgresql://user:pass@ep-noisy-pond-a1nmenkk-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Optional override for production host fingerprint (default is hardcoded)
# PRODUCTION_DB_HOST=ep-noisy-pond-a1nmenkk-pooler.ap-southeast-1.aws.neon.tech

# Disposable Neon branch for restore round-trip proof (scripts/restore-validate-neon.sh)
# RESTORE_TEST_DATABASE_URL=postgresql://user:pass@ep-restore-test-pooler.region.aws.neon.tech/neondb?sslmode=require
