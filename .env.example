# ── Database configuration ────────────────────────────────────────────────────
#
# DEVELOPMENT (NODE_ENV=development):
#   LOCAL_DATABASE_URL → local PostgreSQL, never Neon
#   DATABASE_URL       → same local URL so migration scripts work without extra setup
#
# PRODUCTION VPS (NODE_ENV=production):
#   DATABASE_URL → Neon pooler URL
#   LOCAL_DATABASE_URL is not set on the server
#
# The app validates this at startup and refuses to start if the wrong DB is bound.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Local development ─────────────────────────────────────────────────────────
# Point both to your local PostgreSQL. Never put a Neon URL here.
LOCAL_DATABASE_URL=postgresql://postgres:yourpassword@127.0.0.1:5432/saachu
DATABASE_URL=postgresql://postgres:yourpassword@127.0.0.1:5432/saachu

# ── Production VPS only — do not set these locally ───────────────────────────
# NODE_ENV=production
# DATABASE_URL=postgresql://neondb_owner:...@ep-noisy-pond-a1nmenkk-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Optional ──────────────────────────────────────────────────────────────────
# Override production host fingerprint check (default is hardcoded in database-environment.ts)
# PRODUCTION_DB_HOST=ep-noisy-pond-a1nmenkk-pooler.ap-southeast-1.aws.neon.tech
